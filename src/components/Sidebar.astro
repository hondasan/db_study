---
import { getCollection } from 'astro:content';

interface Props {
  currentId?: string;
}

const { currentId } = Astro.props;

// 全記事を取得してソート
const posts = await getCollection('db-study');
posts.sort((a, b) => a.data.order - b.data.order);

// カテゴリごとにグループ化
const groupedPosts = posts.reduce((acc, post) => {
  const category = post.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const categories = Object.keys(groupedPosts);
---

<aside class="sidebar-container">
  <div class="sidebar-header">
    <a href="/" class="sidebar-logo">
      <span class="logo-emoji">🗄️</span>
      <span class="logo-text">db_study</span>
    </a>
  </div>

  <nav class="sidebar-nav">
    <!-- ホーム・概要リンク -->
    <div class="nav-group">
      <ul class="nav-list">
        <li class="nav-item">
          <a href="/" class={`nav-link ${!currentId ? 'active' : ''}`}>
            <svg class="doc-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            <span class="nav-link-text">概要 (Overview)</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- カテゴリ別の記事リンク -->
    {categories.map((category) => (
      <div class="nav-group">
        <h3 class="nav-group-title">{category}</h3>
        <ul class="nav-list">
          {groupedPosts[category].map((post) => {
            const isActive = currentId === post.id;
            return (
              <li class="nav-item">
                <a 
                  href={`/${post.id}`} 
                  class={`nav-link ${isActive ? 'active' : ''}`}
                >
                  <svg class="doc-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                  <span class="nav-link-text">{post.data.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar-container {
    width: var(--sidebar-width);
    background-color: var(--bg-primary); /* メイン背景と同一化 */
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  .sidebar-header {
    height: var(--header-height);
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    color: var(--text-primary);
  }

  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .nav-group {
    display: flex;
    flex-direction: column;
  }

  .nav-group-title {
    font-size: 0.725rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    padding-left: 0.5rem;
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.5rem;
    border-radius: 0.375rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    background-color: var(--bg-hover);
    color: var(--text-primary);
  }

  .nav-link.active {
    color: var(--accent-color);
    font-weight: 500;
    background-color: transparent; /* 背景は塗らずテキストハイライトに */
  }

  .doc-icon {
    flex-shrink: 0;
    opacity: 0.5;
    width: 14px;
    height: 14px;
    transition: opacity 0.15s ease;
  }

  .nav-link:hover .doc-icon {
    opacity: 0.8;
  }

  .nav-link.active .doc-icon {
    color: var(--accent-color);
    opacity: 1;
  }

  .nav-link-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* レスポンシブ */
  @media (max-width: 900px) {
    .sidebar-container {
      transform: translateX(-100%);
      background-color: var(--bg-primary);
      box-shadow: 0 0 15px rgba(0, 0, 0, 0.05);
    }

    .sidebar-container.open {
      transform: translateX(0);
    }
  }
</style>
