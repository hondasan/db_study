---
interface Props {
  title: string;
  description?: string;
  currentId?: string;
}

const { title, description = "データベースとSQLを体系的に学ぶ学習サイト", currentId } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - db_study</title>
    <!-- Google Fonts: Newsreader (Serif), Inter (Sans-serif), Fira Code (Mono) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;500;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="app-container">
      <!-- 左サイドバー -->
      <slot name="sidebar" />

      <div class="main-container">
        <!-- ヘッダー -->
        <header class="app-header">
          <button id="menu-toggle" class="menu-toggle-btn" aria-label="メニューを開く">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          </button>
          
          <div class="header-logo">
            <span class="logo-emoji">🗄️</span>
            <span class="logo-text">db_study</span>
          </div>

          <div class="header-actions">
            <!-- GitHub Link -->
            <a href="https://github.com/hondasan/db_study" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub Repository">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            </a>
            
            <!-- Theme Toggle Button -->
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="テーマを切り替え">
              <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
              <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </button>
          </div>
        </header>

        <!-- 3カラム化 (メインコンテンツ + 右サイドバー) -->
        <div class="layout-columns">
          <main class="content-wrapper">
            <article class="prose-container">
              <slot />
            </article>
          </main>
          
          <!-- 右側目次 (存在する場合のみ表示) -->
          {Astro.slots.has('toc') && (
            <aside class="toc-wrapper">
              <slot name="toc" />
            </aside>
          )}
        </div>
      </div>
    </div>

    <!-- サイドバー用のモバイルオーバーレイ -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <script>
      // テーマ管理
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const theme = getTheme();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }

      window.localStorage.setItem('theme', theme);

      const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      }

      document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);

      // モバイルメニュー管理
      const menuToggle = document.getElementById('menu-toggle');
      const sidebarOverlay = document.getElementById('sidebar-overlay');
      
      const toggleSidebar = () => {
        document.querySelector('.sidebar-container')?.classList.toggle('open');
        sidebarOverlay?.classList.toggle('active');
        document.body.classList.toggle('sidebar-open');
      };

      menuToggle?.addEventListener('click', toggleSidebar);
      sidebarOverlay?.addEventListener('click', toggleSidebar);

      // コードコピー機能
      const setupCopyButtons = () => {
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-code-btn')) return;

          const button = document.createElement('button');
          button.className = 'copy-code-btn';
          button.type = 'button';
          button.setAttribute('aria-label', 'コードをコピー');
          button.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            <span class="copy-status">コピー</span>
          `;

          pre.style.position = 'relative';
          pre.appendChild(button);

          button.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            if (!code) return;

            try {
              await navigator.clipboard.writeText(code.innerText);
              button.classList.add('copied');
              const statusEl = button.querySelector('.copy-status');
              if (statusEl) statusEl.textContent = 'コピー完了';
              
              setTimeout(() => {
                button.classList.remove('copied');
                if (statusEl) statusEl.textContent = 'コピー';
              }, 2000);
            } catch (err) {
              console.error('Failed to copy text: ', err);
            }
          });
        });
      };

      setupCopyButtons();
      document.addEventListener('astro:page-load', setupCopyButtons);
    </script>
  </body>
</html>

<style is:global>
  /* Claude Docsライクな洗練されたCSS変数定義 */
  :root {
    --bg-primary: #FAF9F6; /* Claude Docsの極めて薄いウォームホワイト */
    --bg-secondary: #FAF9F6; /* サイドバーも同色にしてシームレスに */
    --bg-hover: #F3EFE9;
    --bg-tertiary: #EBE5DB;
    
    --text-primary: #191919;
    --text-secondary: #5C5852;
    --text-muted: #8E8A83;
    
    --border-color: #ECEAE3; /* 非常に薄い境界線 */
    --border-hover: #D7CFC2;
    
    --accent-color: #C97B63; /* Claude特有のレンガ・コッパー色 */
    --accent-hover: #A05944;
    --accent-light: #F7EBE7;
    
    --code-bg: #F5F2EC;
    --code-text: #1E293B;
    
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.02);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    
    --font-serif: 'Newsreader', 'Georgia', 'Noto Serif JP', serif;
    --font-sans: 'Inter', 'Noto Sans JP', system-ui, -apple-system, sans-serif;
    --font-mono: 'Fira Code', monospace;
    
    --sidebar-width: 280px;
    --toc-width: 240px;
    --header-height: 60px;
    --max-content-width: 800px;
  }

  .dark {
    --bg-primary: #141413; /* Claude Docsのダーク背景 */
    --bg-secondary: #141413;
    --bg-hover: #1D1D1C;
    --bg-tertiary: #262624;
    
    --text-primary: #ECEBE8;
    --text-secondary: #9E9D97;
    --text-muted: #72726E;
    
    --border-color: #242422;
    --border-hover: #333330;
    
    --accent-color: #DA7B6C;
    --accent-hover: #EC9A8D;
    --accent-light: #2D1E1B;
    
    --code-bg: #1A1A19;
    --code-text: #E2E8F0;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .app-container {
    display: flex;
    min-height: 100vh;
    position: relative;
  }

  .main-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    margin-left: var(--sidebar-width);
    transition: margin-left 0.2s ease;
  }

  /* ヘッダー (極めてミニマル) */
  .app-header {
    height: var(--header-height);
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    position: sticky;
    top: 0;
    z-index: 50;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .menu-toggle-btn {
    display: none;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.375rem;
  }

  .menu-toggle-btn:hover {
    background-color: var(--bg-hover);
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1rem;
    color: var(--text-primary);
  }

  .logo-emoji {
    font-size: 1.1rem;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .github-link, .theme-toggle-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .github-link:hover, .theme-toggle-btn:hover {
    background-color: var(--bg-hover);
    color: var(--text-primary);
  }

  .sun-icon { display: block; }
  .moon-icon { display: none; }
  .dark .sun-icon { display: none; }
  .dark .moon-icon { display: block; }

  /* 3カラム（メインコンテンツ + 右目次）レイアウト定義 */
  .layout-columns {
    display: flex;
    flex: 1;
    position: relative;
  }

  .content-wrapper {
    flex: 1;
    padding: 3rem 3rem 6rem 3rem;
    display: flex;
    justify-content: center;
    overflow-y: auto;
  }

  .prose-container {
    width: 100%;
    max-width: var(--max-content-width);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  /* 目次 (右カラム) */
  .toc-wrapper {
    width: var(--toc-width);
    flex-shrink: 0;
    border-left: 1px solid var(--border-color);
    padding: 3rem 1.5rem;
    position: sticky;
    top: var(--header-height);
    height: calc(100vh - var(--header-height));
    overflow-y: auto;
    background-color: var(--bg-primary);
    transition: border-color 0.2s ease;
  }

  /* Markdownタイポグラフィの刷新 (Newsreaderセリフ体の導入) */
  .prose-container h1 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .prose-container h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border-color);
    line-height: 1.3;
  }

  .prose-container h3 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .prose-container p {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }

  .prose-container ul, .prose-container ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
  }

  .prose-container li {
    margin-bottom: 0.5rem;
  }

  .prose-container strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .prose-container hr {
    border: 0;
    border-top: 1px solid var(--border-color);
    margin: 3rem 0;
  }

  .prose-container blockquote {
    border-left: 2px solid var(--accent-color);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--text-secondary);
    margin: 2rem 0;
    font-family: var(--font-serif);
    font-size: 1.15rem;
  }

  /* コードブロックのカスタマイズ */
  .prose-container pre {
    background-color: var(--code-bg) !important;
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .prose-container pre.shiki {
    background-color: var(--code-bg) !important;
  }

  .prose-container pre code span {
    color: var(--shiki-light);
  }
  .dark .prose-container pre code span {
    color: var(--shiki-dark) !important;
  }

  .prose-container code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    background-color: var(--code-bg);
    color: var(--text-primary);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border-color);
  }

  .prose-container pre code {
    padding: 0;
    background-color: transparent;
    border: none;
    border-radius: 0;
    font-size: 0.85rem;
  }

  /* コピーボタンのスタイル */
  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background-color: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 0.25rem;
    padding: 0.2rem 0.4rem;
    font-size: 0.7rem;
    color: var(--text-secondary);
    cursor: pointer;
    opacity: 0;
    transition: all 0.15s ease;
    z-index: 10;
  }

  pre:hover .copy-code-btn {
    opacity: 1;
  }

  .copy-code-btn:hover {
    background-color: var(--bg-hover);
    color: var(--text-primary);
  }

  .copy-code-btn.copied {
    background-color: var(--accent-light);
    color: var(--accent-color);
    border-color: var(--accent-color);
  }

  .copy-icon {
    flex-shrink: 0;
  }

  /* モバイルオーバーレイ */
  .sidebar-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(1px);
    z-index: 80;
  }

  /* レスポンシブ */
  @media (max-width: 1100px) {
    .toc-wrapper {
      display: none; /* タブレット以下では右目次を非表示 */
    }
  }

  @media (max-width: 900px) {
    .main-container {
      margin-left: 0;
    }

    .app-header {
      padding: 0 1rem;
    }

    .menu-toggle-btn {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .content-wrapper {
      padding: 2rem 1.25rem;
    }

    .sidebar-overlay.active {
      display: block;
    }

    body.sidebar-open {
      overflow: hidden;
    }
  }
</style>
